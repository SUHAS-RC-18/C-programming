#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Student {
    int id;
    char name[50];
    char attendance[10];
};

FILE *fp;

// Function declarations
void addRecord();
void markAttendance();
void viewAttendance();
void menu();

int main() {
    menu();
    return 0;
}

// Menu function
void menu() {
    int choice;

    while (1) {
        printf("\n===== ATTENDANCE MANAGEMENT SYSTEM =====\n");
        printf("1. Add Student Record\n");
        printf("2. Mark Attendance\n");
        printf("3. View Attendance Report\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addRecord(); break;
            case 2: markAttendance(); break;
            case 3: viewAttendance(); break;
            case 4:
                printf("\nExiting program...\n");
                exit(0);
            default:
                printf("\nInvalid choice! Please try again.\n");
        }
    }
}

// Function to add new student record
void addRecord() {
    struct Student s;

    fp = fopen("attendance.dat", "ab");
    if (fp == NULL) {
        printf("Error opening file!\n");
        return;
    }

    printf("\nEnter Student ID: ");
    scanf("%d", &s.id);
    getchar(); // clear buffer

    printf("Enter Student Name: ");
    fgets(s.name, sizeof(s.name), stdin);
    s.name[strcspn(s.name, "\n")] = 0; // remove newline

    strcpy(s.attendance, "Absent");

    fwrite(&s, sizeof(s), 1, fp);
    fclose(fp);

    printf("Record added successfully!\n");
}

// Function to mark attendance
void markAttendance() {
    struct Student s;
    int id, found = 0;

    fp = fopen("attendance.dat", "rb+");
    if (fp == NULL) {
        printf("No records found. Please add records first.\n");
        return;
    }

    printf("\nEnter Student ID to mark attendance: ");
    scanf("%d", &id);

    while (fread(&s, sizeof(s), 1, fp)) {
        if (s.id == id) {
            found = 1;

            printf("Student Found: %s\n", s.name);
            printf("Enter Attendance (Present/Absent): ");
            scanf("%s", s.attendance);

            fseek(fp, -sizeof(s), SEEK_CUR);
            fwrite(&s, sizeof(s), 1, fp);

            printf("Attendance updated successfully!\n");
            break;
        }
    }

    if (!found)
        printf("Record not found!\n");

    fclose(fp);
}

// Function to view attendance
void viewAttendance() {
    struct Student s;

    fp = fopen("attendance.dat", "rb");
    if (fp == NULL) {
        printf("No records available.\n");
        return;
    }

    printf("\n===== ATTENDANCE REPORT =====\n");
    printf("%-10s %-25s %-10s\n", "ID", "Name", "Attendance");
    printf("---------------------------------------------\n");

    while (fread(&s, sizeof(s), 1, fp)) {
        printf("%-10d %-25s %-10s\n", s.id, s.name, s.attendance);
    }

    fclose(fp);
}
